tos minclock 3 maxclock 6

{% for server in servers -%}
pool {{ server }} iburst
{% endfor %}

restrict default limited kod nomodify notrap noquery nopeer
restrict source  limited kod nomodify notrap noquery
restrict 127.0.0.1
restrict ::1

leapfile "/var/db/ntpd.leap-seconds.list"
